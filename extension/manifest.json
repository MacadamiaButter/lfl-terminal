{
  "manifest_version": 3,
  "name": "lfl-terminal",
  "version": "0.4.0",
  "description": "Browser terminal with deterministic commands and a local LLM that proposes page actions you approve. Nothing leaves your machine.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Toggle lfl-terminal (or press `)",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["storage"],
  "host_permissions": ["http://127.0.0.1:1238/*"],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "content/guards.js",
        "content/ratelimit.js",
        "content/axtree.js",
        "content/nav-watch.js",
        "content/registry.js",
        "content/nav.js",
        "content/engine.js",
        "content/executor.js",
        "content/funpack.js",
        "content/games.js",
        "content/terminal.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
